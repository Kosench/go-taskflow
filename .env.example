# Application
APP_ENV=development
TASKQUEUE_APP_NAME=task-queue

# Database
TASKQUEUE_DATABASE_HOST=localhost
TASKQUEUE_DATABASE_PORT=5432
TASKQUEUE_DATABASE_NAME=taskqueue
TASKQUEUE_DATABASE_USER=taskqueue
TASKQUEUE_DATABASE_PASSWORD=taskqueue

# Kafka
TASKQUEUE_KAFKA_BROKERS=localhost:9092
TASKQUEUE_KAFKA_CONSUMER_GROUP_ID=task-workers

# API
TASKQUEUE_SERVER_HTTP_PORT=8081
TASKQUEUE_SERVER_GRPC_PORT=50051

# Worker
TASKQUEUE_WORKER_CONCURRENCY=5
TASKQUEUE_METRICS_PORT=8082
